# Copy this file to .env.local and fill in your real keys.
# .env.local is already gitignored by Next.js — never commit real keys.

# Primary provider
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Fallback provider (get a free key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Used only for OpenRouter's optional attribution headers
APP_URL=http://localhost:3000

# Second fallback provider (free, get a key at https://opencode.ai/zen)
OPENCODEZEN_API_KEY=sk-...
OPENCODEZEN_MODEL=big-pickle

# Neon Postgres — get this from your Neon project dashboard
# (Connection string, "Pooled connection" is fine for the HTTP driver)
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/interviewiq?sslmode=require
